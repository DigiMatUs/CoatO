        <https://w3id.org/coato/#coat_00111>
    
    
Class: <https://w3id.org/coato/#coat_00113>

    Annotations: 
        <http://purl.obolibrary.org/obo/IAO_0000115> "Pumping speed is the volumetric flow through the pump's intake port."@en,
        <http://purl.obolibrary.org/obo/IAO_0000119> "https://content.leybold.com/en/knowledge/what-is-the-definition-of-pumping-speed"^^xsd:anyURI,
        rdfs:label "pumping speed"@en
    
    SubClassOf: 
        <https://w3id.org/coato/#coat_00089>
    
    
