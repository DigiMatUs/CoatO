        rdfs:seeAlso "http://purl.allotrope.org/ontologies/quality#AFQ_0000112"
    
    SubClassOf: 
        <https://w3id.org/pmd/co/PMD_0000512>
    
    
Class: <https://w3id.org/coato/#coat_00112>

