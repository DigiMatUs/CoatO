    Annotations: 
        <http://purl.obolibrary.org/obo/IAO_0000115> "Electron temperature is a thermal quality that characterizes the average kinetic energy of electrons in a plasma.",
        rdfs:label "Elektronentemperatur"@de,
        rdfs:label "electron temperature"@en
    
    SubClassOf: 
        <https://w3id.org/coato/#coat_00096>,
