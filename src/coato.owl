    SubPropertyOf: 
        <http://purl.obolibrary.org/obo/RO_0000053>
    
    
ObjectProperty: <http://purl.obolibrary.org/obo/RO_0002233>

    Annotations: 
        <http://purl.obolibrary.org/obo/IAO_0000115> "p has input c iff: p is a process, c is a material entity, c is a participant in p, c is present at the start of p, and the state of c is modified during p."@en,
        rdfs:label "has input"@en,
        rdfs:label "hat Input"@de
    
    SubPropertyOf: 
        <http://purl.obolibrary.org/obo/RO_0000057>
    
    
ObjectProperty: <http://purl.obolibrary.org/obo/RO_0002234>

    Annotations: 
        <http://purl.obolibrary.org/obo/IAO_0000115> "p has output c iff c is a participant in p, c is present at the end of p, and c is not present in the same state at the beginning of p."@en,
        rdfs:label "has output"@en,
        rdfs:label "hat Output"@de
    
    SubPropertyOf: 
        <http://purl.obolibrary.org/obo/RO_0000057>
    
    
ObjectProperty: <http://purl.obolibrary.org/obo/RO_0002333>

    Annotations: 
        <http://purl.obolibrary.org/obo/IAO_0000115> "p is enabled by c iff c is capable of p and c acts to execute p."@en,
        rdfs:label "enabled by"@en
    
    SubPropertyOf: 
        <http://purl.obolibrary.org/obo/RO_0000057>
    
    
ObjectProperty: <http://purl.obolibrary.org/obo/RO_0002505>

    Annotations: 
        <http://purl.obolibrary.org/obo/IAO_0000115> "p has intermediate c if and only if p has parts p1, p2 and p1 has output c, and p2 has input c"@en,
        rdfs:label "has intermediate"@en
    
    SubPropertyOf: 
        <http://purl.obolibrary.org/obo/RO_0000057>
    
    
ObjectProperty: <http://purl.obolibrary.org/obo/RO_0004008>

    Annotations: 
        <http://purl.obolibrary.org/obo/IAO_0000115> "p has primary output c if (a) p has output c and (b) the goal of process is to modify, produce, or transform c."@en,
        rdfs:label "has primary output"@en,
        rdfs:label "hat primären Output"@de
    
    SubPropertyOf: 
        <http://purl.obolibrary.org/obo/RO_0002234>
    
    
